{
  "name": "@ngm-dev/mat-exp",
  "version": "0.0.0-alpha.0",
  "description": "Angular Material Expressive is a library that provides a set of components and styles for Angular Material based on the latest Material Design 3 Expressive Design System.",
  "keywords": [
    "angular",
    "material",
    "expressive",
    "design system",
    "components",
    "styles"
  ],
  "author": {
    "name": "Dharmen Shah",
    "url": "https://github.com/shhdharmen"
  },
  "publishConfig": {
    "access": "public"
  },
  "bugs": {
    "url": "https://github.com/Angular-Material-Dev/mat-exp/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Angular-Material-Dev/mat-exp"
  },
  "homepage": "https://expressive.angular-material.dev/",
  "scripts": {
    "build": "npm run build:sass",
    "build:sass": "sass --pkg-importer=node -I ../../../node_modules ./src/lib/styles/prebuilt.scss:../../../dist/ngm-dev/mat-exp/src/styles/styles.css",
    "postbuild": "copyfiles schematics/*/schema.json schematics/collection.json ../../../dist/ngm-dev/mat-exp/"
  },
  "peerDependencies": {
    "@angular/common": "^21.1.0",
    "@angular/core": "^21.1.0",
    "@angular/material": "^21.1.0",
    "gsap": "^3.13.0"
  },
  "dependencies": {
    "tslib": "^2.3.0"
  },
  "license": "MIT",
  "sideEffects": false,
  "schematics": "./schematics/collection.json",
  "ng-add": {
    "save": "dependencies"
  },
  "exports": {
    ".": {
      "sass": "./src/lib/styles/_index.scss"
    },
    "./styles.css": {
      "style": "./src/styles/styles.css"
    },
    "./schematics/*": "./schematics/*"
  }
}
