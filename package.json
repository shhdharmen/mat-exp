{
  "name": "mat-exp-docs",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "watch:lib": "ng build --watch --configuration development --project @ngm-dev/mat-exp",
    "test": "ng test --project mat-exp-docs",
    "copy": "cpx README.md dist/ngm-dev/mat-exp",
    "generate:style-constants": "tsx scripts/generate-style-constants.ts",
    "build:schematics": "tsc -p projects/ngm-dev/mat-exp/schematics/tsconfig.schematics.json",
    "pretest:schematics": "npm run build:schematics",
    "test:schematics": "vitest run projects/ngm-dev/mat-exp/schematics",
    "prebuild:lib": "npm run generate:style-constants && npm run build:schematics",
    "lint:tokens": "tsx scripts/lint-token-files.ts",
    "build:lib": "ng build @ngm-dev/mat-exp --configuration production && npm run copy",
    "postbuild:lib": "npm run build --prefix ./projects/ngm-dev/mat-exp",
    "prepare": "husky",
    "commit": "cz",
    "build:docs": "tsx scripts/build-docs.ts && ng build && tsx scripts/fix-redirect-html-lang.ts && npx pagefind --site dist/mat-exp-docs/browser --output-path dist/mat-exp-docs/browser/_pagefind",
    "postbuild:docs": "tsx scripts/generate-sitemap.ts && tsx scripts/generate-llms-txt.ts",
    "prelint": "npm run lint:tokens",
    "lint": "ng lint",
    "new:component": "tsx scripts/new-component.ts"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "packageManager": "npm@11.13.0",
  "dependencies": {
    "@angular/cdk": "~21.2.12",
    "@angular/common": "^21.2.14",
    "@angular/compiler": "^21.2.14",
    "@angular/core": "^21.2.14",
    "@angular/elements": "^21.2.14",
    "@angular/forms": "^21.2.14",
    "@angular/material": "~21.2.12",
    "@angular/platform-browser": "^21.2.14",
    "@angular/router": "^21.2.14",
    "@davidlj95/ngx-meta": "^21.0.1",
    "@shikijs/transformers": "^4.1.0",
    "gray-matter": "^4.0.3",
    "gsap": "^3.15.0",
    "marked": "^15.0.12",
    "marked-alert": "^2.1.2",
    "rxjs": "~7.8.0",
    "shiki": "^4.1.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular-devkit/schematics": "^21.2.12",
    "@angular/build": "^21.2.12",
    "@angular/cli": "^21.2.12",
    "@angular/compiler-cli": "^21.2.14",
    "@angular/platform-server": "21.2.14",
    "@angular/ssr": "^21.2.12",
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@tailwindcss/postcss": "^4.3.0",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^25.9.1",
    "angular-eslint": "21.4.0",
    "cpx": "^1.5.0",
    "cz-conventional-changelog": "^3.3.0",
    "eslint": "^10.3.0",
    "husky": "^9.1.7",
    "jsdom": "^27.1.0",
    "lint-staged": "^17.0.5",
    "ng-packagr": "^21.1.0",
    "playwright-ng-schematics": "^21.1.0",
    "postcss": "^8.5.3",
    "prettier": "^3.8.3",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.22.3",
    "typescript": "~5.9.2",
    "typescript-eslint": "8.59.2",
    "vitest": "^4.0.8"
  },
  "lint-staged": {
    "*.{js,json,css,scss,ts,html,component.html}": [
      "prettier --write"
    ],
    "*.{ts,html}": [
      "eslint --fix"
    ]
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Angular-Material-Dev/mat-exp"
  },
  "publishConfig": {
    "access": "restricted"
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  }
}
