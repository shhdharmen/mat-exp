{
  "compilerOptions": {
    "rootDir": ".",
    "outDir": ".",
    "target": "es2020",
    "module": "node16",
    "moduleResolution": "node16",
    "lib": ["es2020"],
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "declaration": false,
    "sourceMap": false,
    "types": ["node"]
  },
  "include": ["**/*.ts"],
  "exclude": ["**/*.spec.ts"]
}
