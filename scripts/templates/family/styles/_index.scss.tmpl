@use './config';
@use '../../../utils/functions';
@use '../../../utils/mixins';
@use '@angular/material' as mat;
@use 'sass:map';

$_mat-exp-__KEBAB__-class: '__HOST_CLASS__';

@mixin mat-exp-__KEBAB__-styles(
  $options: (
    skip-html-element-styles: false,
  )
) {
  $skip-html-element-styles: map.get($options, skip-html-element-styles);
  $mat-exp-__KEBAB__-class: '.' + $_mat-exp-__KEBAB__-class;

  // Validate the entire configuration
  $validation-result: functions.validate-config(
    config.$__KEBAB__-config,
    functions.$default-allowed-keys,
    '__KEBAB__-config'
  );

  @if $validation-result != true {
    @error $validation-result;
  }

  // Process each combination item in the list
  @each $item in config.$__KEBAB__-config {
    // Extract tokens and properties
    $item-tokens: map.get($item, tokens);
    $item-properties: map.get($item, properties);

    // Build the selector based on the attributes present
    $selector: $mat-exp-__KEBAB__-class;

    // Check for size attribute
    @if map.has-key($item, size) {
      $size: map.get($item, size);
      $selector: $selector + "[data-size='#{$size}']";
    }

    // Check for shape attribute
    @if map.has-key($item, shape) {
      $shape: map.get($item, shape);
      $selector: $selector + "[data-shape='#{$shape}']";
    }

    // Check for toggle attribute
    @if map.has-key($item, toggle) {
      $toggle: map.get($item, toggle);
      $selector: $selector + "[data-toggle='#{$toggle}']";
    }

    // Check for state attribute
    @if map.has-key($item, state) {
      $state: map.get($item, state);
      $pseudo-selector: functions.get-state-pseudo($state);

      // Generate styles with data attribute selector
      #{$selector}[data-state='#{$state}'] {
        @include mixins.apply-tokens-properties(
            $item-tokens,
            $item-properties,
            $skip-html-element-styles
          )
          using ($slot) {
          @if $slot == tokens {
            // TODO: once you've confirmed the Angular Material token API for
            // the host component this styles, uncomment and point this at the
            // right override mixin, e.g. `@include mat.button-overrides($item-tokens);`.
            // Grep `node_modules/@angular/material/core/tokens/` (or the
            // Material docs "Styling" tab) for the exact mixin name — it
            // will not always be `mat.__OVERRIDES_FN__-overrides`.
            // @include mat.__OVERRIDES_FN__-overrides($item-tokens);
          }
        }
      }

      // Also generate styles with CSS pseudo-selector if available
      @if $pseudo-selector {
        #{$selector}#{$pseudo-selector} {
          @include mixins.apply-tokens-properties(
              $item-tokens,
              $item-properties,
              $skip-html-element-styles
            )
            using ($slot) {
            @if $slot == tokens {
              // @include mat.__OVERRIDES_FN__-overrides($item-tokens);
            }
          }
        }
      }
    } @else {
      // No state attribute, generate styles directly
      #{$selector} {
        @include mixins.apply-tokens-properties(
            $item-tokens,
            $item-properties,
            $skip-html-element-styles
          )
          using ($slot) {
          @if $slot == tokens {
            // @include mat.__OVERRIDES_FN__-overrides($item-tokens);
          }
        }
      }
    }
  }
}
